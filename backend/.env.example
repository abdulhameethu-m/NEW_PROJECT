NODE_ENV=development
PORT=5000

# Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/amazon_like
MONGODB_ENABLE_LOCAL_FALLBACK=true
MONGODB_FALLBACK_URI=mongodb://127.0.0.1:27017/amazon_like

# Auth
JWT_ACCESS_SECRET=change_me_super_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
TRACKING_JWT_SECRET=change_me_tracking_secret
STAFF_JWT_ACCESS_SECRET=change_me_staff_access_secret
STAFF_JWT_REFRESH_SECRET=change_me_staff_refresh_secret
STAFF_JWT_ACCESS_EXPIRES_IN=15m
STAFF_JWT_REFRESH_EXPIRES_IN=30d
ENCRYPTION_MASTER_KEY=generate_a_strong_32_plus_char_secret_here

# CORS (comma-separated). Leave empty to allow all in dev.
CORS_ORIGINS=http://localhost:5173

# Rate limiting
AUTH_RATE_LIMIT_MAX=60
API_RATE_LIMIT_MAX=5000

# Uploads
MAX_FILE_SIZE_BYTES=5242880
REEL_MAX_UPLOAD_BYTES=104857600

# Cloudinary (preferred). If not set, local storage fallback used.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Razorpay
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_PAYOUT_SOURCE_ACCOUNT=

# Shiprocket
# LOGISTICS_PROVIDER=SHIPROCKET
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
# SHIPROCKET_WEBHOOK_SECRET=

# Twilio WhatsApp
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# TWILIO_ORDER_SHIPPED_CONTENT_SID=

# Optional: if you explicitly want admin self-registration (not recommended)
ALLOW_ADMIN_REGISTRATION=false

# Admin bootstrap (use with: npm run seed:admin)
ADMIN_NAME=Platform Admin
ADMIN_PHONE=9999999999
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Jobs and queue
SETTLEMENT_SCHEDULER_MODE=auto
SETTLEMENT_JOB_SCHEDULE=*/10 * * * * *
SETTLEMENT_BATCH_SIZE=50
SETTLEMENT_MAX_RETRIES=3
SETTLEMENT_ENABLE_CRON_FALLBACK=true
PAYOUT_DELAY_DAYS=0
MIN_PAYOUT_REQUEST_AMOUNT=500
PAYMENT_MAINTENANCE_CRON=*/15 * * * *
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

