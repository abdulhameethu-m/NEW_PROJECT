NODE_ENV=development
PORT=5000

# Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/amazon_like

# Auth
JWT_ACCESS_SECRET=change_me_super_secret
JWT_ACCESS_EXPIRES_IN=15m

# CORS (comma-separated). Leave empty to allow all in dev.
CORS_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT_MAX=300

# Uploads
MAX_FILE_SIZE_BYTES=5242880

# Cloudinary (preferred). If not set, local storage fallback used.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: if you explicitly want admin self-registration (not recommended)
ALLOW_ADMIN_REGISTRATION=false

# Admin bootstrap (use with: npm run seed:admin)
ADMIN_NAME=Platform Admin
ADMIN_PHONE=9999999999
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

